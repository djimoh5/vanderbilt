{
	"compilerOptions": {
		"target": "ES2017",
		"module": "commonjs",
		"esModuleInterop": true,
		"sourceMap": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"lib": [ "ES2017", "dom" ],
		"removeComments": false,
		"noImplicitAny": false,
		"noUnusedLocals": true,
    	"noUnusedParameters": true,
		"outDir": "../build",
		"rootDir": "../",
		"allowJs": true,
		"skipLibCheck": true,
		"strictNullChecks": false,
		"strict": false
	},
	"exclude": [
		"**/node_modules/"
	]
}